# Copier en .env (jamais commité — voir .gitignore). Aucun secret réel ici.

# Base PostgreSQL (chiffrement au repos côté hébergeur)
DATABASE_URL="postgresql://user:password@localhost:5432/clinikdia?schema=public"

# Secret de signature des sessions JWT — générer une valeur forte aléatoire
# ex: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-with-a-long-random-value"
JWT_EXPIRES_IN="30m"

# Origine autorisée du front (CORS)
CORS_ORIGIN="http://localhost:5180"

# 'production' active les cookies Secure + SameSite=strict
NODE_ENV="development"
PORT="3001"
